DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/english_app?schema=public"

# Auth.js / NextAuth v5
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Comma-separated email(s) of real users that should be promoted to Admin.
# The user must already exist by registering or signing in first.
ADMIN_EMAILS="admin@example.com"

# Google OAuth.
# Google Console redirect URI for local development:
# http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Alternative names also supported by the app:
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Vercel Cron secret — dùng để auth cho endpoint /api/cron/*.
# Generate: openssl rand -hex 32
# Vercel project sẽ tự inject header Authorization: Bearer ${CRON_SECRET} khi gọi cron.
# Local dev: set trong .env.local, dùng curl với -H "Authorization: Bearer $CRON_SECRET" để test.
CRON_SECRET=""

