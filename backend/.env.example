APP_NAME=Web_HoTroPhatAmEN API
APP_VERSION=0.1.0
APP_ENV=development

# Use the same PostgreSQL database as the frontend if backend needs DB checks.
DATABASE_URL=postgresql://postgres:password@localhost:5432/english_app

# Comma-separated origins for FastAPI CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010
